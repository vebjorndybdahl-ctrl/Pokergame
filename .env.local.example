# Copy this file to ".env.local" and fill in the two values from your Supabase
# project: Dashboard > Project Settings > API.

# "Project URL"
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# "service_role" secret key (NOT the anon key). Server-only -- never exposed
# to the browser. Keep it out of git (.env.local is gitignored).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
